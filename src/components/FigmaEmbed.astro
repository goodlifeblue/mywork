---
const { url = '', height = 640, compact = false } = Astro.props;
let iframeSrc = '';
if (url) {
  if (url.includes('embed.figma.com')) {
    iframeSrc = url;
  } else {
    iframeSrc = `https://www.figma.com/embed?embed_host=share&url=${encodeURIComponent(url)}`;
  }
}
---

{compact ? (
  url ? (
    <div class="figma-embed-wrapper relative aspect-[3/5] rounded-2xl overflow-hidden border border-slate-100 bg-white shadow-sm">
      <iframe
        src={iframeSrc}
        class="figma-embed-iframe absolute inset-0 h-full w-full"
        style="border:0;"
        allowfullscreen
      />
      <button
        type="button"
        class="figma-embed-overlay absolute inset-0 hidden flex-col items-center justify-center gap-2 bg-transparent text-white"
      >
        <span class="rounded-full border border-white/20 bg-white/80 px-4 py-2 text-xs uppercase tracking-[0.24em] text-slate-900 shadow-sm">
          點擊啟用 Figma
        </span>
      </button>
    </div>
  ) : (
    <div class="figma-embed-placeholder rounded-xl border border-dashed border-slate-200 bg-slate-50 p-6 text-slate-600 text-center">
      尚未提供 Figma 分享連結。
    </div>
  )
) : (
  <section id="figma" class="mx-auto max-w-[1220px] px-6 pb-24">
    <div class="mb-6">
      <span class="text-sm font-semibold uppercase tracking-wider text-brand-600">Design</span>
      <h3 class="text-xl font-bold tracking-tight text-slate-900">Figma Prototype</h3>
    </div>

    {url ? (
      <div class="figma-embed-wrapper relative rounded-2xl overflow-hidden border border-slate-100 bg-white shadow-sm">
        <iframe
          src={iframeSrc}
          class="figma-embed-iframe w-full"
          style={`height:${height}px; border:0;`}
          allowfullscreen
        />
        <button
          type="button"
          class="figma-embed-overlay absolute inset-0 hidden flex-col items-center justify-center gap-2 bg-transparent text-white"
        >
          <span class="rounded-full border border-white/20 bg-white/80 px-4 py-2 text-xs uppercase tracking-[0.24em] text-slate-900 shadow-sm">
            點擊啟用 Figma
          </span>
        </button>
      </div>
    ) : (
      <div class="figma-embed-placeholder rounded-xl border border-dashed border-slate-200 bg-slate-50 p-6 text-slate-600">
        尚未提供 Figma 分享連結。要顯示 Figma 嵌入，請在 `<FigmaEmbed url="https://www.figma.com/file/...." />` 設定分享網址。
      </div>
    )}
  </section>
)}

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.figma-embed-wrapper').forEach((wrapper) => {
      const iframe = wrapper.querySelector('iframe');
      const overlay = wrapper.querySelector('.figma-embed-overlay');
      if (!iframe || !overlay) return;

      const enableIframe = () => {
        overlay.classList.add('hidden');
        iframe.style.pointerEvents = 'auto';
      };

      if (window.innerWidth < 640) {
        overlay.classList.remove('hidden');
        iframe.style.pointerEvents = 'none';
        overlay.addEventListener('click', enableIframe);
        overlay.addEventListener('keydown', (event) => {
          if (event.key === 'Enter' || event.key === ' ') {
            enableIframe();
          }
        });
      } else {
        iframe.style.pointerEvents = 'auto';
      }
    });
  });
</script>
