---
// 專業技能(icon 為 24x24 線條 SVG 的內部路徑)
const categories = [
  {
    icon: '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>',
    title: "產品設計",
    skills: ["產品規劃", "UI／UX 設計", "Web／Mobile 產品設計", "遊戲畫面 UI 設計", "娛樂城遊戲大廳設計", "體育賽事投注介面", "後台 System UI", "User Flow"],
  },
  {
    icon: '<circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>',
    title: "使用者研究",
    skills: ["使用者研究", "使用者訪談", "可用性測試", "A/B Testing"],
  },
  {
    icon: '<circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/>',
    title: "設計工具",
    skills: ["Figma", "Design System", "Component Library", "Photoshop", "Illustrator"],
  },
  {
    icon: '<rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/>',
    title: "前端技術",
    skills: ["HTML5／CSS3", "SCSS／SASS", "Tailwind CSS", "Bootstrap", "Vuetify", "Element UI", "RWD", "UI Motion"],
  },
  {
    icon: '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>',
    title: "開發與協作",
    skills: ["Git／GitFlow", "VS Code", "Jira", "Scrum"],
  },
  {
    icon: '<path d="M20.2 6 3 11l-.9-2.4c-.3-1.1.3-2.2 1.3-2.5l13.5-4c1.1-.3 2.2.3 2.5 1.3Z"/><path d="m6.2 5.3 3.1 3.9"/><path d="m12.4 3.4 3.1 4"/><path d="M3 11h18v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2Z"/>',
    title: "動態設計與影音",
    skills: ["After Effects", "Premiere Pro", "Motion Graphics", "UI Motion", "產品展示影片"],
  },
  {
    icon: '<path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/>',
    title: "AI 與創作工具",
    skills: ["ChatGPT", "Claude", "Vibe Coding", "AI 圖像生成", "AI 影片生成", "AI 輔助設計"],
  },
];
---

<section id="skills" class="bg-brand-50/50">
  <div class="mx-auto max-w-[1220px] px-6 py-15">
    <div class="mb-12 flex flex-col gap-3">
      <span class="text-sm font-semibold uppercase tracking-wider text-brand-600">
        Skills
      </span>
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
        專業技能
      </h2>
    </div>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        categories.map((cat) => (
          <div class="rounded-2xl border border-slate-100 bg-white p-6">
            <h3 class="mb-4 flex items-center gap-2 text-base font-semibold text-slate-900">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="shrink-0 text-brand-600"
                aria-hidden="true"
                set:html={cat.icon}
              />
              {cat.title}
            </h3>
            <div class="flex flex-wrap gap-2">
              {cat.skills.map((skill) => (
                <span class="rounded-md bg-brand-50 px-2.5 py-1 text-xs font-medium text-brand-700">
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
