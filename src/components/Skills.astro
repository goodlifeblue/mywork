---
// 專業技能
const categories = [
  {
    icon: "🎯",
    title: "產品設計",
    skills: ["產品規劃", "UI／UX 設計", "Web／Mobile 產品設計", "遊戲畫面 UI 設計", "娛樂城遊戲大廳設計", "體育賽事投注介面", "後台 System UI", "User Flow"],
  },
  {
    icon: "🔍",
    title: "使用者研究",
    skills: ["使用者研究", "使用者訪談", "可用性測試", "A/B Testing"],
  },
  {
    icon: "🎨",
    title: "設計工具",
    skills: ["Figma", "Design System", "Component Library", "Photoshop", "Illustrator"],
  },
  {
    icon: "💻",
    title: "前端技術",
    skills: ["HTML5／CSS3", "SCSS／SASS", "Tailwind CSS", "Bootstrap", "Vuetify", "Element UI", "RWD", "UI Motion"],
  },
  {
    icon: "🔧",
    title: "開發與協作",
    skills: ["Git／GitFlow", "VS Code", "Jira", "Scrum"],
  },
  {
    icon: "🎬",
    title: "動態設計與影音",
    skills: ["After Effects", "Premiere Pro", "Motion Graphics", "UI Motion", "產品展示影片"],
  },
  {
    icon: "🤖",
    title: "AI 與創作工具",
    skills: ["ChatGPT", "Claude", "Vibe Coding", "AI 圖像生成", "AI 影片生成", "AI 輔助設計"],
  },
];
---

<section id="skills" class="bg-brand-50/50">
  <div class="mx-auto max-w-[1220px] px-6 py-15">
    <div class="mb-12 flex flex-col gap-3">
      <span class="text-sm font-semibold uppercase tracking-wider text-brand-600">
        Skills
      </span>
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
        專業技能
      </h2>
    </div>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        categories.map((cat) => (
          <div class="rounded-2xl border border-slate-100 bg-white p-6">
            <h3 class="mb-4 flex items-center gap-2 text-base font-semibold text-slate-900">
              <span class="text-xl">{cat.icon}</span>
              {cat.title}
            </h3>
            <div class="flex flex-wrap gap-2">
              {cat.skills.map((skill) => (
                <span class="rounded-md bg-brand-50 px-2.5 py-1 text-xs font-medium text-brand-700">
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
