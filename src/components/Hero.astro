---
// 個人介紹區
const roles = ["Senior Product Designer", "Design Lead", "UI/UX Designer"];

// 金銀圓球：從照片中心噴出散開（twinkle = 閃爍發光）
const balls = [
  { color: "#F3E3AC", size: 14, tx: -138, ty: -109, delay: 0.05, float: 3.1 },
  { color: "#E4E8EF", size: 10, tx: 69,   ty: -150, delay: 0.15, float: 3.7, twinkle: 1.6 },
  { color: "#E6C96E", size: 16, tx: 155,  ty: -69,  delay: 0.25, float: 3.3 },
  { color: "#C9CFD9", size: 9,  tx: 173,  ty: 35,   delay: 0.35, float: 4.0, twinkle: 2.2 },
  { color: "#AEB6C2", size: 13, tx: 127,  ty: 121,  delay: 0.45, float: 3.5 },
  { color: "#FFFDF5", size: 11, tx: 23,   ty: 167,  delay: 0.55, float: 3.9, twinkle: 1.9 },
  { color: "#D9B84A", size: 15, tx: -104, ty: 138,  delay: 0.65, float: 3.2 },
  { color: "#FFFFFF", size: 10, tx: -167, ty: 46,   delay: 0.75, float: 4.2, twinkle: 2.4 },
  { color: "#F5E7BC", size: 12, tx: -178, ty: -40,  delay: 0.85, float: 3.6 },
  { color: "#CDD3DC", size: 8,  tx: -52,  ty: -161, delay: 0.95, float: 3.8, twinkle: 1.7 },
  { color: "#E6C96E", size: 7,  tx: 115,  ty: -132, delay: 1.05, float: 4.1, twinkle: 2.0 },
  { color: "#E4E8EF", size: 9,  tx: -132, ty: -144, delay: 1.15, float: 3.4 },
  // 細小粒子：增加顆粒感與閃爍
  { color: "#E9C84F", size: 5, tx: -92,  ty: -184, delay: 0.1,  float: 2.8, twinkle: 1.3 },
  { color: "#F3E3AC", size: 4, tx: 17,   ty: -190, delay: 0.2,  float: 3.0, twinkle: 1.5 },
  { color: "#E4E8EF", size: 6, tx: 104,  ty: -173, delay: 0.3,  float: 3.3, twinkle: 1.8 },
  { color: "#E6C96E", size: 4, tx: 184,  ty: -115, delay: 0.4,  float: 2.9, twinkle: 1.4 },
  { color: "#C9CFD9", size: 5, tx: 201,  ty: -6,   delay: 0.5,  float: 3.5, twinkle: 2.1 },
  { color: "#E9C84F", size: 4, tx: 196,  ty: 104,  delay: 0.6,  float: 3.1, twinkle: 1.2 },
  { color: "#AEB6C2", size: 6, tx: 150,  ty: 167,  delay: 0.7,  float: 3.4, twinkle: 1.9 },
  { color: "#F5E7BC", size: 4, tx: 63,   ty: 196,  delay: 0.8,  float: 2.7, twinkle: 1.6 },
  { color: "#FFFFFF", size: 5, tx: -46,  ty: 190,  delay: 0.9,  float: 3.6, twinkle: 2.0 },
  { color: "#E9C84F", size: 4, tx: -144, ty: 173,  delay: 1.0,  float: 3.0, twinkle: 1.3 },
  { color: "#D9B84A", size: 6, tx: -196, ty: 98,   delay: 1.1,  float: 3.2, twinkle: 1.7 },
  { color: "#CDD3DC", size: 4, tx: -207, ty: 6,    delay: 1.2,  float: 2.9, twinkle: 1.5 },
  { color: "#E6C96E", size: 5, tx: -196, ty: -92,  delay: 1.3,  float: 3.3, twinkle: 1.8 },
  { color: "#E9C84F", size: 4, tx: -23,  ty: -201, delay: 1.4,  float: 3.1, twinkle: 1.4 },
];
---

<section
  id="about"
  class="relative overflow-hidden bg-gradient-to-b from-brand-50/70 to-white/30"
>
  <!-- 裝飾光暈 -->
  <div
    class="pointer-events-none absolute -right-24 -top-24 h-72 w-72 rounded-full bg-brand-200/50 blur-3xl"
  >
  </div>

  <div class="mx-auto max-w-[1220px] px-6 pt-24 pb-16 sm:pt-32 sm:pb-20">
    <div class="fade-up grid items-center gap-12 lg:grid-cols-[1fr_auto]">
      <!-- 文字 -->
      <div class="flex flex-col items-start gap-6">
        <h1
          class="text-2xl font-extrabold leading-tight tracking-tight text-slate-900 sm:text-3xl"
        >
          我是 <span class="text-brand-600">藍怡婷</span>
        </h1>

        <p class="flex flex-wrap items-center gap-x-3 gap-y-1 text-lg font-medium text-slate-500">
          {
            roles.map((role, i) => (
              <>
                {i > 0 && <span class="text-brand-300">·</span>}
                <span>{role}</span>
              </>
            ))
          }
        </p>

        <div class="flex max-w-2xl flex-col gap-3 text-[15px] leading-relaxed text-slate-600">
          <p>
            擁有 10+ 年產品設計經驗，專精於 Web／Mobile 與遊戲介面設計，負責需求釐清、流程規劃、Wireframe、
            UI 視覺設計、Design System 建置與設計交付，並與 PM、RD 共同協作優化使用體驗。
          </p>
          <p>
            深耕娛樂城與體育賽事平台多年，熟悉體育賽事的賠率呈現、投注流程與即時數據介面，
            擅長將複雜資訊整理為清楚易操作的介面，提升產品互動與娛樂體驗。
          </p>
          <p>
            近年持續精進 AI 應用，將 AI 工具導入設計流程與內容產製，加速迭代並探索更多創意可能。
          </p>
        </div>

        <div class="flex flex-wrap gap-3 pt-2">
          <a
            href="#portfolio"
            class="rounded-full bg-brand-600 px-6 py-3 text-sm font-semibold text-white shadow-sm transition-all hover:bg-brand-700 hover:shadow-md"
          >
            查看作品集
          </a>
          <a
            href="#experience"
            class="rounded-full border border-slate-200 bg-white px-6 py-3 text-sm font-semibold text-slate-700 transition-colors hover:border-brand-300 hover:text-brand-600"
          >
            查看經歷
          </a>
          <a
            href="#contact"
            class="rounded-full border border-slate-200 bg-white px-6 py-3 text-sm font-semibold text-slate-700 transition-colors hover:border-brand-300 hover:text-brand-600"
          >
            聯絡我
          </a>
        </div>

        <!-- 專長標籤 -->
        <div class="flex flex-wrap gap-2 pt-6">
          {
            ["產品規劃", "UI／UX 設計", "Design System", "設計團隊管理", "Figma", "Motion Design"].map(
              (tag) => (
                <span class="rounded-md bg-white px-3 py-1 text-sm text-slate-500 shadow-sm ring-1 ring-slate-100">
                  {tag}
                </span>
              )
            )
          }
        </div>
      </div>

      <!-- 照片 -->
      <div class="order-first flex justify-center lg:order-last">
        <div class="relative">
          <div class="pointer-events-none absolute inset-0" aria-hidden="true">
            {
              balls.map((b) => (
                <span
                  class="ball-burst"
                  style={`--tx:${b.tx}px; --ty:${b.ty}px; --pop-delay:${b.delay}s;`}
                >
                  <span
                    class={`block rounded-full ${b.twinkle ? "ball-twinkle" : "decor-float"}`}
                    style={`width:${b.size}px; height:${b.size}px; background:${b.color}; color:${b.color}; --float-dur:${b.float}s; --twinkle-dur:${b.twinkle || 2}s;`}
                  />
                </span>
              ))
            }
          </div>
          <!-- 綠色外圈點綴 -->
          <div
            class="absolute -inset-2 rounded-full bg-gradient-to-br from-brand-300 to-brand-100"
          >
          </div>
          <img
            src="/me.jpg"
            alt="藍怡婷 Yiting Lan"
            width="230"
            height="230"
            class="relative h-[230px] w-[230px] rounded-full object-cover object-top shadow-xl ring-4 ring-white"
          />
          <!-- 年資標籤 -->
          <div
            class="absolute bottom-2 right-2 z-10 flex flex-col items-center rounded-full bg-white px-3 py-2 shadow-lg ring-1 ring-slate-100"
          >
            <span class="text-lg font-extrabold leading-none text-brand-600">10+</span>
            <span class="mt-0.5 text-[10px] font-medium leading-none text-slate-500">年經驗</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* 飄動：上下浮動 + 輕微搖擺 */
  .decor-float {
    animation: decor-float var(--float-dur, 3.5s) ease-in-out infinite;
  }

  @keyframes decor-float {
    0%,
    100% {
      transform: translateY(0) rotate(-5deg);
    }
    50% {
      transform: translateY(-9px) rotate(5deg);
    }
  }

  /* 閃爍：飄動 + 呼吸發光 */
  .ball-twinkle {
    animation:
      decor-float var(--float-dur, 3.5s) ease-in-out infinite,
      ball-twinkle var(--twinkle-dur, 2s) ease-in-out infinite;
  }

  @keyframes ball-twinkle {
    0%,
    100% {
      opacity: 1;
      box-shadow: 0 0 6px 2px currentColor;
    }
    50% {
      opacity: 0.35;
      box-shadow: 0 0 1px 0 currentColor;
    }
  }

  /* 彩色圓球：從中心噴出到定位 */
  .ball-burst {
    position: absolute;
    top: 50%;
    left: 50%;
    opacity: 0;
    transform: translate(-50%, -50%) scale(0);
    animation: ball-burst 0.9s cubic-bezier(0.22, 1.4, 0.36, 1) forwards;
    animation-delay: var(--pop-delay, 0s);
  }

  @keyframes ball-burst {
    from {
      opacity: 0;
      transform: translate(-50%, -50%) scale(0);
    }
    40% {
      opacity: 1;
    }
    to {
      opacity: 1;
      transform: translate(calc(-50% + var(--tx)), calc(-50% + var(--ty))) scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ball-burst {
      animation: none;
      opacity: 1;
      transform: translate(calc(-50% + var(--tx)), calc(-50% + var(--ty))) scale(1);
    }
    .decor-float,
    .ball-twinkle {
      animation: none;
    }
  }
</style>
