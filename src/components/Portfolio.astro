---
import { Image } from "astro:assets";

// 自動抓取 src/assets/works/ 底下三個資料夾的所有檔案
// 之後只要把新檔案丟進對應資料夾，作品集就會自動顯示，不需修改程式碼。
const toSorted = (mods) =>
  Object.entries(mods)
    .sort(([a], [b]) => a.localeCompare(b))
    .map(([path, src]) => ({
      name: path.split("/").pop().replace(/\.[^.]+$/, ""),
      src,
    }));

const webImages = toSorted(
  import.meta.glob("../assets/works/web/*.{jpg,jpeg,png,webp}", {
    eager: true,
    import: "default",
  })
);
const logoImages = toSorted(
  import.meta.glob("../assets/works/logo/*.{jpg,jpeg,png,webp,svg}", {
    eager: true,
    import: "default",
  })
);
const videoFiles = toSorted(
  import.meta.glob("../assets/works/video/*.mp4", {
    eager: true,
    import: "default",
    query: "?url",
  })
);
const posterFiles = toSorted(
  import.meta.glob("../assets/works/video/*.{jpg,jpeg,png}", {
    eager: true,
    import: "default",
  })
);

// 影片與縮圖依檔名對應（video01.mp4 ↔ video01.jpg）
const videos = videoFiles.map((v, i) => ({
  ...v,
  poster: posterFiles[i]?.src,
}));

// Figma prototype 輪播清單
const figmaPrototypes = [
  "https://embed.figma.com/proto/gTkN7pHX1zH2b8hTuLBfxD/SPORT?node-id=4425-18305&viewport=167%2C121%2C0.5&scaling=scale-down-width&content-scaling=fixed&starting-point-node-id=4425%3A18305&page-id=4425%3A18303&hide-ui=1&embed-host=share",
  "https://embed.figma.com/proto/0MVNyt8rQYXf3vqhoBrHBp/E-UI-Labiry?node-id=350-513&viewport=928%2C-1103%2C0.25&scaling=scale-down-width&content-scaling=fixed&starting-point-node-id=436%3A2618&page-id=346%3A384&hide-ui=1&embed-host=share",
  "https://embed.figma.com/proto/kcTH8v03htyMjG1GmFElcK/%E8%A8%AD%E8%A8%88%E4%B8%AD--Copy-?node-id=33443-321&viewport=422%2C114%2C1.14&scaling=scale-down-width&content-scaling=fixed&page-id=33443%3A320&hide-ui=1&embed-host=share",
];

// 圖片類別（網頁、Logo）
const imageCategories = [
  {
    id: "web",
    icon: "🌐",
    title: "網頁設計",
    subtitle: "Web Design",
    desc: "Web／Mobile 產品與品牌官網介面設計，注重 RWD 與使用體驗。",
    items: webImages,
    fit: "cover", // 整頁截圖 → 裁切顯示頂部
    zoomable: true, // 可點擊放大
  },
  {
    id: "logo",
    icon: "✏️",
    title: "Logo 設計",
    desc: "品牌識別與 Logo 設計。",
    items: logoImages,
    fit: "contain", // Logo → 完整顯示不裁切
    zoomable: false, // 完整顯示、不需放大
  },
];
---

<section id="portfolio" class="mx-auto max-w-[1220px] px-6 pt-12 pb-24">
  <div class="mb-12 flex flex-col gap-3">
    <span class="text-sm font-semibold uppercase tracking-wider text-brand-600">
      Portfolio
    </span>
    <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
      作品集
    </h2>
    <p class="max-w-2xl text-slate-600">
      精選作品分為網頁設計、Logo 設計與影片三大類別。
    </p>
  </div>

  <div class="flex flex-col gap-20">
    <!-- 圖片類別（網頁、Logo）-->
    {
      imageCategories.map((cat) => (
        <div id={cat.id}>
          <div class="mb-8 flex flex-wrap items-end justify-between gap-3 border-b border-slate-100 pb-4">
            <div class="flex items-center gap-3">
              <span class="flex h-11 w-11 items-center justify-center rounded-xl bg-brand-50 text-2xl">
                {cat.icon}
              </span>
              <div>
                <h3 class="text-xl font-bold text-slate-900">{cat.title}</h3>
                {cat.subtitle ? (
                  <p class={cat.id === 'logo' ? 'hidden text-sm font-medium uppercase tracking-wide text-brand-500 sm:block' : 'text-sm font-medium uppercase tracking-wide text-brand-500'}>
                    {cat.subtitle}
                  </p>
                ) : null}
              </div>
            </div>
            <p class="max-w-md text-sm text-slate-500">{cat.desc}</p>
          </div>

          {cat.id === 'logo' ? (
            <div class="logo-gallery rounded-3xl border border-slate-100 bg-white p-4 shadow-sm sm:p-6">
              <div class="hidden gap-6 lg:grid lg:grid-cols-[1.1fr_0.9fr]">
                <div class="rounded-2xl border border-slate-100 bg-gradient-to-br from-brand-50 to-white p-0">
                  <div class="flex flex-col gap-0">
                    <div class="relative aspect-[4/3] overflow-hidden rounded-2xl bg-white">
                      <img
                        src={cat.items[0]?.src?.src || ""}
                        alt={`${cat.title} 01`}
                        class="logo-main-image h-full w-full object-contain transition-all duration-500"
                      />
                    </div>
                  </div>
                </div>

                <div class="flex flex-wrap justify-center gap-3">
                  {cat.items.map((item, i) => (
                    <button
                      type="button"
                      class="logo-thumb group relative aspect-[4/3] w-[calc((100%-1.5rem)/3)] overflow-hidden rounded-xl border-2 border-transparent bg-white p-3 shadow-sm ring-1 ring-slate-100 transition-all hover:ring-brand-200"
                      data-index={i}
                      data-title={`${cat.title} ${String(i + 1).padStart(2, "0")}`}
                      data-src={item.src.src}
                      aria-label={`顯示 ${cat.title} ${String(i + 1).padStart(2, "0")}`}
                    >
                      <img
                        src={item.src.src}
                        alt={`${cat.title} ${i + 1}`}
                        loading="lazy"
                        class="h-full w-full object-contain object-center transition-transform duration-300 group-hover:scale-105"
                      />
                    </button>
                  ))}
                </div>
              </div>

              <div class="grid gap-6 sm:grid-cols-2 lg:hidden">
                {cat.items.map((item, i) => (
                  <div class="group overflow-hidden rounded-2xl border border-slate-100 bg-white transition-all hover:-translate-y-1 hover:border-brand-200 hover:shadow-lg hover:shadow-brand-100/50">
                    <div class="relative block aspect-[4/3] w-full overflow-hidden bg-gradient-to-br from-brand-50 to-brand-100">
                      <Image
                        src={item.src}
                        alt={`${cat.title} ${i + 1}`}
                        loading="lazy"
                        class="h-full w-full object-contain p-4"
                      />
                    </div>
                    <div class="flex items-center justify-between gap-2 p-4">
                      <h4 class="text-sm font-semibold text-slate-900 transition-colors group-hover:text-brand-600">
                        {cat.title} {String(i + 1).padStart(2, "0")}
                      </h4>
                      <span class="rounded-md bg-brand-50 px-2 py-0.5 text-xs font-medium text-brand-700">
                        {cat.subtitle}
                      </span>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ) : (
            <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
              {cat.items.map((item, i) => (
                <div class="group overflow-hidden rounded-2xl border border-slate-100 bg-white transition-all hover:-translate-y-1 hover:border-brand-200 hover:shadow-lg hover:shadow-brand-100/50">
                  {cat.zoomable ? (
                    <button
                      type="button"
                      class="image-trigger group/img relative block aspect-[4/3] w-full cursor-pointer overflow-hidden bg-gradient-to-br from-brand-50 to-brand-100"
                      data-image={item.src.src}
                      aria-label={`放大檢視 ${cat.title} ${i + 1}`}
                    >
                      <Image
                        src={item.src}
                        alt={`${cat.title} ${i + 1}`}
                        loading="lazy"
                        class="h-full w-full object-cover object-top transition-transform duration-500 group-hover/img:object-bottom"
                      />
                      <span class="absolute inset-0 bg-slate-900/0 transition-colors group-hover/img:bg-slate-900/20" />
                      <span class="absolute right-2 top-2 rounded-md bg-slate-900/60 px-1.5 py-0.5 text-xs font-medium text-white">
                        ⛶ 點擊放大
                      </span>
                    </button>
                  ) : (
                    <div class="relative block aspect-[4/3] w-full overflow-hidden bg-gradient-to-br from-brand-50 to-brand-100">
                      <Image
                        src={item.src}
                        alt={`${cat.title} ${i + 1}`}
                        loading="lazy"
                        class="h-full w-full object-contain p-4"
                      />
                    </div>
                  )}
                  <div class="flex items-center justify-between gap-2 p-4">
                    <h4 class="text-sm font-semibold text-slate-900 transition-colors group-hover:text-brand-600">
                      {cat.title} {String(i + 1).padStart(2, "0")}
                    </h4>
                    {cat.subtitle ? (
                      <span class="rounded-md bg-brand-50 px-2 py-0.5 text-xs font-medium text-brand-700">
                        {cat.subtitle}
                      </span>
                    ) : null}
                  </div>
                </div>
              ))}
            </div>
          )}
          {cat.id === 'web' && (
            <>
              <div id="figma">
                <div class="mb-8 flex flex-wrap items-end justify-between gap-3 border-b border-slate-100 py-4">
                  <div class="flex items-center gap-3">
                    <span class="flex h-11 w-11 items-center justify-center rounded-xl bg-brand-50 text-2xl">🎛️</span>
                    <div>
                      <h3 class="text-xl font-bold text-slate-900">Figma</h3>
                      <p class="text-sm font-medium uppercase tracking-wide text-brand-500">Prototype / Design</p>
                    </div>
                  </div>
                  <p class="max-w-md text-sm text-slate-500">Figma prototype 與設計連結展示。</p>
                </div>

                <div class="figma-phone-carousel flex flex-col items-center gap-6">
                  <div class="relative w-[300px] sm:w-[340px]">
                    <div class="relative rounded-[2.75rem] border-[10px] border-slate-900 bg-slate-900 shadow-2xl shadow-slate-900/30">
                      <div class="relative h-[528px] overflow-hidden rounded-[2rem] bg-white sm:h-[613px]">
                        {figmaPrototypes.map((src, i) => (
                          <iframe
                            src={src}
                            title={`Figma Prototype ${i + 1}`}
                            class={`figma-slide absolute inset-0 h-full w-full transition-opacity duration-300 ${i === 0 ? "opacity-100" : "pointer-events-none opacity-0"}`}
                            style="border:0;"
                            allowfullscreen
                          />
                        ))}
                        <div class="figma-loading pointer-events-none absolute inset-0 z-10 flex items-center justify-center bg-white/90 opacity-0 transition-opacity duration-300">
                          <div class="flex flex-col items-center gap-3">
                            <span class="h-10 w-10 animate-spin rounded-full border-4 border-slate-200 border-t-brand-500"></span>
                            <span class="text-xs font-medium tracking-wider text-slate-400">Loading…</span>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>

                  <div class="flex items-center gap-5">
                    <button
                      type="button"
                      class="figma-carousel-prev flex h-10 w-10 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-600 shadow-sm transition-colors hover:border-brand-300 hover:text-brand-600"
                      aria-label="上一個 Prototype"
                    >
                      ←
                    </button>
                    <div class="flex items-center gap-2">
                      {figmaPrototypes.map((_, i) => (
                        <button
                          type="button"
                          class={`figma-carousel-dot h-2.5 w-2.5 rounded-full transition-colors ${i === 0 ? "bg-brand-500" : "bg-slate-200 hover:bg-slate-300"}`}
                          data-index={i}
                          aria-label={`切換到 Prototype ${i + 1}`}
                        />
                      ))}
                    </div>
                    <button
                      type="button"
                      class="figma-carousel-next flex h-10 w-10 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-600 shadow-sm transition-colors hover:border-brand-300 hover:text-brand-600"
                      aria-label="下一個 Prototype"
                    >
                      →
                    </button>
                  </div>
                </div>
              </div>
            </>
          )}
        </div>
      ))
    }

    <!-- 影片類別 -->
    <div id="video">
      <div class="mb-8 flex flex-wrap items-end justify-between gap-3 border-b border-slate-100 pb-4">
        <div class="flex items-center gap-3">
          <span class="flex h-11 w-11 items-center justify-center rounded-xl bg-brand-50 text-2xl">
            🎬
          </span>
          <div>
            <h3 class="text-xl font-bold text-slate-900">影片</h3>
            <p class="text-sm font-medium uppercase tracking-wide text-brand-500">
              Motion / Video
            </p>
          </div>
        </div>
        <p class="max-w-md text-sm text-slate-500">
          產品展示影片、UI Motion 與 Motion Graphics。
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          videos.map((item, i) => (
            <div class="group overflow-hidden rounded-2xl border border-slate-100 bg-white transition-all hover:-translate-y-1 hover:border-brand-200 hover:shadow-lg hover:shadow-brand-100/50">
              <button
                type="button"
                class="video-trigger group/vid relative block aspect-[4/3] w-full cursor-pointer overflow-hidden bg-slate-900"
                data-video={item.src}
                aria-label={`播放影片 ${i + 1}`}
              >
                {item.poster && (
                  <img
                    src={item.poster.src}
                    alt={`影片 ${i + 1}`}
                    loading="lazy"
                    class="h-full w-full object-cover transition-transform duration-300 group-hover/vid:scale-105"
                  />
                )}
                <span class="absolute inset-0 flex items-center justify-center bg-slate-900/25 transition-colors group-hover/vid:bg-slate-900/40">
                  <span class="flex h-14 w-14 items-center justify-center rounded-full bg-white/90 text-brand-600 shadow-lg transition-transform group-hover/vid:scale-110">
                    <svg viewBox="0 0 24 24" fill="currentColor" class="ml-0.5 h-6 w-6">
                      <path d="M8 5v14l11-7z" />
                    </svg>
                  </span>
                </span>
                <span class="absolute right-2 top-2 rounded-md bg-slate-900/60 px-1.5 py-0.5 text-xs font-medium text-white">
                  ⛶ 點擊放大
                </span>
              </button>
              <div class="flex items-center justify-between gap-2 p-4">
                <h4 class="text-sm font-semibold text-slate-900 transition-colors group-hover:text-brand-600">
                  影片 {String(i + 1).padStart(2, "0")}
                </h4>
                <span class="rounded-md bg-brand-50 px-2 py-0.5 text-xs font-medium text-brand-700">
                  Video
                </span>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>

  </div>
</section>

<div
  id="portfolio-category-nav"
  class="fixed inset-x-0 bottom-0 z-40 px-4 pb-4 hidden sm:hidden"
  style="padding-bottom: calc(1rem + env(safe-area-inset-bottom, 0px));"
>
  <div class="mx-auto flex max-w-[1220px] items-center justify-between gap-2 rounded-3xl border border-white/20 bg-brand-500/50 px-3 py-3 text-white shadow-2xl shadow-slate-900/10 backdrop-blur-sm">
    <button
      type="button"
      data-target="web"
      class="portfolio-nav-btn flex-1 rounded-2xl border border-transparent bg-white/10 px-3 py-2 text-xs font-semibold uppercase tracking-[0.24em] transition-colors duration-200"
      aria-pressed="false"
    >
      Web
    </button>
    <button
      type="button"
      data-target="figma"
      class="portfolio-nav-btn flex-1 rounded-2xl border border-transparent bg-white/10 px-3 py-2 text-xs font-semibold uppercase tracking-[0.24em] transition-colors duration-200"
      aria-pressed="false"
    >
      Figma
    </button>
    <button
      type="button"
      data-target="logo"
      class="portfolio-nav-btn flex-1 rounded-2xl border border-transparent bg-white/10 px-3 py-2 text-xs font-semibold uppercase tracking-[0.24em] transition-colors duration-200"
      aria-pressed="false"
    >
      Logo
    </button>
    <button
      type="button"
      data-target="video"
      class="portfolio-nav-btn flex-1 rounded-2xl border border-transparent bg-white/10 px-3 py-2 text-xs font-semibold uppercase tracking-[0.24em] transition-colors duration-200"
      aria-pressed="false"
    >
      影片
    </button>
  </div>
</div>
<script>
  const portfolioNav = document.getElementById('portfolio-category-nav');
  const portfolioSection = document.getElementById('portfolio');
  const portfolioButtons = document.querySelectorAll('.portfolio-nav-btn');

  function updateNavState(activeId) {
    portfolioButtons.forEach((btn) => {
      const isActive = btn.dataset.target === activeId;
      btn.classList.toggle('border-white/80', isActive);
      btn.classList.toggle('bg-white/20', isActive);
      btn.setAttribute('aria-pressed', String(isActive));
    });
  }

  function showPortfolioNav() {
    if (!portfolioNav) return;
    portfolioNav.classList.remove('hidden');
  }

  function hidePortfolioNav() {
    if (!portfolioNav) return;
    portfolioNav.classList.add('hidden');
  }

  if (portfolioSection && portfolioNav) {
    const isPortfolioInView = () => {
      const rect = portfolioSection.getBoundingClientRect();
      return rect.bottom > 0 && rect.top < window.innerHeight;
    };

    const updatePortfolioNavVisibility = () => {
      if (isPortfolioInView()) {
        showPortfolioNav();
      } else {
        hidePortfolioNav();
      }
    };

    updatePortfolioNavVisibility();
    window.addEventListener('scroll', updatePortfolioNavVisibility, { passive: true });
    window.addEventListener('resize', updatePortfolioNavVisibility);

    portfolioButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const targetId = btn.dataset.target;
        const target = document.getElementById(targetId);
        if (!target) return;
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        updateNavState(targetId);
      });
    });

    updateNavState('web');
  }
</script>

<!-- 圖片燈箱 Lightbox（整頁截圖可捲動）-->
<div
  id="image-lightbox"
  class="fixed inset-0 z-[100] hidden grid place-items-center overflow-y-auto bg-slate-900/85 p-4 backdrop-blur-sm sm:p-8"
>
  <div class="relative w-full max-w-3xl pt-[10px]">
    <button
      id="image-lightbox-close"
      type="button"
      class="mx-auto mb-[10px] flex h-[20px] min-w-[100px] items-center justify-center rounded-2xl bg-white/20 px-[10px] text-xs font-semibold text-white backdrop-blur-md transition-colors hover:bg-white/30"
    >
      close
    </button>
    <img
      id="image-lightbox-img"
      src=""
      alt=""
      class="mx-auto w-full rounded-xl shadow-2xl"
    />
  </div>
</div>

<!-- 影片燈箱 Lightbox -->
<div
  id="video-lightbox"
  class="fixed inset-0 z-[100] hidden items-center justify-center bg-slate-900/80 p-4 backdrop-blur-sm"
>
  <button
    id="video-lightbox-close"
    type="button"
    aria-label="關閉"
    class="absolute right-4 top-4 flex h-11 w-11 items-center justify-center rounded-full bg-white/10 text-2xl text-white transition-colors hover:bg-white/20"
  >
    ✕
  </button>
  <video
    id="video-lightbox-player"
    controls
    playsinline
    class="max-h-[85vh] w-full max-w-4xl rounded-2xl bg-black shadow-2xl"
  >
  </video>
</div>

<script>
  const logoGallery = document.querySelector('.logo-gallery');
  const logoMainImage = document.querySelector('.logo-main-image') as HTMLImageElement | null;
  const logoMainTitle = document.querySelector('.logo-main-title');
  const logoThumbs = document.querySelectorAll<HTMLButtonElement>('.logo-thumb');

  if (logoGallery && logoMainImage) {
    const images = Array.from(logoThumbs).map((thumb) => ({
      src: thumb.dataset.src || '',
      title: thumb.dataset.title || 'Logo',
    }));

    let currentIndex = 0;
    let autoplayTimer: number | undefined;
    let isHovered = false;

    function updateMainImage(index: number) {
      const item = images[index];
      if (!item) return;
      logoMainImage.src = item.src;
      logoMainImage.alt = item.title;
      if (logoMainTitle) logoMainTitle.textContent = item.title;
      currentIndex = index;
      logoThumbs.forEach((thumb, thumbIndex) => {
        thumb.classList.toggle('border-brand-500', thumbIndex === index);
        thumb.classList.toggle('shadow-md', thumbIndex === index);
      });
    }

    function startAutoplay() {
      if (images.length <= 1) return;
      clearInterval(autoplayTimer);
      autoplayTimer = window.setInterval(() => {
        if (isHovered) return;
        const nextIndex = (currentIndex + 1) % images.length;
        updateMainImage(nextIndex);
      }, 2500);
    }

    logoThumbs.forEach((thumb) => {
      thumb.addEventListener('click', () => {
        const index = Number(thumb.dataset.index || 0);
        updateMainImage(index);
        startAutoplay();
      });
    });

    logoGallery.addEventListener('mouseenter', () => {
      isHovered = true;
      clearInterval(autoplayTimer);
    });

    logoGallery.addEventListener('mouseleave', () => {
      isHovered = false;
      startAutoplay();
    });

    updateMainImage(0);
    startAutoplay();
  }

  // Figma 手機輪播
  const figmaCarousel = document.querySelector('.figma-phone-carousel');
  if (figmaCarousel) {
    const slides = figmaCarousel.querySelectorAll<HTMLIFrameElement>('.figma-slide');
    const dots = figmaCarousel.querySelectorAll<HTMLButtonElement>('.figma-carousel-dot');
    const loadingOverlay = figmaCarousel.querySelector('.figma-loading');
    const slideLoaded = new Array(slides.length).fill(false);
    let figmaIndex = 0;
    let loadingHideTimer: number | undefined;

    function setLoading(visible: boolean) {
      loadingOverlay?.classList.toggle('opacity-0', !visible);
      loadingOverlay?.classList.toggle('opacity-100', visible);
    }

    slides.forEach((slide, i) => {
      slide.addEventListener('load', () => {
        slideLoaded[i] = true;
        if (i === figmaIndex) setLoading(false);
      });
    });

    // 首個 prototype 載入前先顯示 loading
    if (!slideLoaded[0]) setLoading(true);

    function showFigmaSlide(index: number) {
      figmaIndex = (index + slides.length) % slides.length;
      slides.forEach((slide, i) => {
        slide.classList.toggle('opacity-100', i === figmaIndex);
        slide.classList.toggle('opacity-0', i !== figmaIndex);
        slide.classList.toggle('pointer-events-none', i !== figmaIndex);
      });
      dots.forEach((dot, i) => {
        dot.classList.toggle('bg-brand-500', i === figmaIndex);
        dot.classList.toggle('bg-slate-200', i !== figmaIndex);
      });

      // 切換時顯示 loading：已載入的短暫過場，未載入的等 load 事件
      clearTimeout(loadingHideTimer);
      setLoading(true);
      if (slideLoaded[figmaIndex]) {
        loadingHideTimer = window.setTimeout(() => setLoading(false), 400);
      }
    }

    // 自動輪播：8 秒切換，滑鼠移入（操作 prototype）時暫停
    let figmaAutoplayTimer: number | undefined;
    let figmaHovered = false;

    function startFigmaAutoplay() {
      clearInterval(figmaAutoplayTimer);
      figmaAutoplayTimer = window.setInterval(() => {
        if (figmaHovered) return;
        showFigmaSlide(figmaIndex + 1);
      }, 8000);
    }

    figmaCarousel.addEventListener('mouseenter', () => {
      figmaHovered = true;
    });
    figmaCarousel.addEventListener('mouseleave', () => {
      figmaHovered = false;
    });

    figmaCarousel.querySelector('.figma-carousel-prev')?.addEventListener('click', () => {
      showFigmaSlide(figmaIndex - 1);
      startFigmaAutoplay();
    });
    figmaCarousel.querySelector('.figma-carousel-next')?.addEventListener('click', () => {
      showFigmaSlide(figmaIndex + 1);
      startFigmaAutoplay();
    });
    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        showFigmaSlide(Number(dot.dataset.index || 0));
        startFigmaAutoplay();
      });
    });

    startFigmaAutoplay();
  }

  // 影片燈箱
  const lightbox = document.getElementById("video-lightbox");
  const player = document.getElementById("video-lightbox-player") as HTMLVideoElement | null;
  const closeBtn = document.getElementById("video-lightbox-close");

  function openLightbox(src: string) {
    if (!lightbox || !player) return;
    player.src = src;
    lightbox.classList.remove("hidden");
    lightbox.classList.add("flex");
    document.body.style.overflow = "hidden";
    player.play().catch(() => {});
  }

  function closeLightbox() {
    if (!lightbox || !player) return;
    player.pause();
    player.removeAttribute("src");
    player.load();
    lightbox.classList.add("hidden");
    lightbox.classList.remove("flex");
    document.body.style.overflow = "";
  }

  document.querySelectorAll<HTMLButtonElement>(".video-trigger").forEach((btn) => {
    btn.addEventListener("click", () => {
      const src = btn.getAttribute("data-video");
      if (src) openLightbox(src);
    });
  });

  closeBtn?.addEventListener("click", closeLightbox);
  lightbox?.addEventListener("click", (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  // 圖片燈箱
  const imgLightbox = document.getElementById("image-lightbox");
  const imgEl = document.getElementById("image-lightbox-img") as HTMLImageElement | null;
  const imgCloseBtn = document.getElementById("image-lightbox-close");

  function openImageLightbox(src: string) {
    if (!imgLightbox || !imgEl) return;
    imgEl.src = src;
    imgLightbox.scrollTop = 0;
    imgLightbox.classList.remove("hidden");
    document.body.style.overflow = "hidden";
  }

  function closeImageLightbox() {
    if (!imgLightbox || !imgEl) return;
    imgEl.removeAttribute("src");
    imgLightbox.classList.add("hidden");
    document.body.style.overflow = "";
  }

  document.querySelectorAll<HTMLButtonElement>(".image-trigger").forEach((btn) => {
    btn.addEventListener("click", () => {
      const src = btn.getAttribute("data-image");
      if (src) openImageLightbox(src);
    });
  });

  imgCloseBtn?.addEventListener("click", closeImageLightbox);
  imgLightbox?.addEventListener("click", (e) => {
    if (e.target === imgLightbox) closeImageLightbox();
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      closeLightbox();
      closeImageLightbox();
    }
  });
</script>
