---
// 金色流線背景：多條平行細線組成的緞帶曲線，緩慢飄移（滿版固定鋪底）
// 產生兩組曲線家族，每組由數十條偏移的貝茲曲線構成
const LINES = 32;

const ribbonA = Array.from({ length: LINES }, (_, i) => {
  const o = i * 10;
  return `M ${1060 + o} -80
          C ${830 + o * 0.7} 240, ${1380 - o * 0.5} 430, ${1120 + o * 0.4} 660
          S ${770 + o * 0.8} 950, ${1030 + o * 0.6} 1300`;
});

// 左側曲線：右側緞帶的水平鏡像（用 SVG transform 翻轉）

// 金色發光粒子：畫面中間散布
const particles = [
  { x: 520,  y: 340, r: 2.6, dur: 2.2, delay: 0 },
  { x: 640,  y: 260, r: 1.8, dur: 2.8, delay: 0.4 },
  { x: 790,  y: 300, r: 2.2, dur: 2.5, delay: 0.8 },
  { x: 730,  y: 420, r: 1.6, dur: 3.1, delay: 1.2 },
  { x: 590,  y: 470, r: 2.4, dur: 2.4, delay: 0.2 },
  { x: 480,  y: 560, r: 1.8, dur: 2.9, delay: 0.9 },
  { x: 660,  y: 620, r: 2.8, dur: 2.1, delay: 0.5 },
  { x: 820,  y: 580, r: 1.5, dur: 3.3, delay: 1.5 },
  { x: 940,  y: 520, r: 2.1, dur: 2.6, delay: 0.3 },
  { x: 1040, y: 600, r: 1.7, dur: 2.7, delay: 1.0 },
  { x: 880,  y: 700, r: 2.3, dur: 2.3, delay: 0.7 },
  { x: 720,  y: 780, r: 1.9, dur: 3.0, delay: 1.3 },
  { x: 560,  y: 720, r: 2.0, dur: 2.5, delay: 0.6 },
  { x: 430,  y: 260, r: 1.6, dur: 2.8, delay: 1.1 },
];
---

<div class="gold-waves pointer-events-none fixed inset-0 -z-10 overflow-hidden" aria-hidden="true">
  <svg
    class="absolute inset-0 h-full w-full"
    viewBox="0 0 1600 1200"
    fill="none"
    preserveAspectRatio="xMidYMid slice"
  >
    <defs>
      <!-- 金色漸層：深金 → 香檳金 → 亮金高光 → 深金 -->
      <linearGradient
        id="gold-line"
        gradientUnits="userSpaceOnUse"
        x1="0"
        y1="0"
        x2="1600"
        y2="1200"
      >
        <stop offset="0%" stop-color="#8a6a35" />
        <stop offset="30%" stop-color="#c3a76f" />
        <stop offset="50%" stop-color="#f7ecca" />
        <stop offset="70%" stop-color="#c3a76f" />
        <stop offset="100%" stop-color="#8a6a35" />
        <!-- 高光沿線條流動 -->
        <animateTransform
          attributeName="gradientTransform"
          type="translate"
          values="-600,-800; 600,800; -600,-800"
          dur="10s"
          repeatCount="indefinite"
        />
      </linearGradient>

      <!-- 粒子光暈：亮金中心向外淡出 -->
      <radialGradient id="gold-halo">
        <stop offset="0%" stop-color="#f7ecca" stop-opacity="0.9" />
        <stop offset="40%" stop-color="#d5c095" stop-opacity="0.35" />
        <stop offset="100%" stop-color="#d5c095" stop-opacity="0" />
      </radialGradient>
    </defs>

    <g class="wave-drift-a" opacity="0.5">
      {ribbonA.map((d) => (
        <path d={d} stroke="url(#gold-line)" stroke-width="1" />
      ))}
    </g>

    <g transform="translate(1600, 280) scale(-1, 1)" opacity="0.22">
      <g class="wave-drift-b">
        {ribbonA.map((d) => (
          <path d={d} stroke="url(#gold-line)" stroke-width="0.8" />
        ))}
      </g>
    </g>

    <!-- 金色發光粒子 -->
    <g>
      {particles.map((p) => (
        <g
          class="gold-particle"
          style={`--dur:${p.dur}s; animation-delay:${p.delay}s;`}
        >
          <circle cx={p.x} cy={p.y} r={p.r * 4} fill="url(#gold-halo)" />
          <circle cx={p.x} cy={p.y} r={p.r} fill="#f2e3b8" />
        </g>
      ))}
    </g>
  </svg>
</div>

<script>
  // 手機停用 SVG SMIL 漸層流光動畫（CSS 管不到），降低耗能
  if (window.matchMedia('(max-width: 640px)').matches) {
    document.querySelectorAll<SVGSVGElement>('.gold-waves svg').forEach((svg) => {
      svg.pauseAnimations();
    });
  }
</script>

<style>
  /* 緩慢飄移 + 輕微搖擺，兩組相位錯開 */
  .wave-drift-a {
    transform-origin: 60% 50%;
    animation: wave-drift-a 14s ease-in-out infinite alternate;
  }

  .wave-drift-b {
    transform-origin: 55% 45%;
    animation: wave-drift-b 18s ease-in-out infinite alternate;
  }

  @keyframes wave-drift-a {
    from {
      transform: translateY(-18px) rotate(-1.2deg);
    }
    to {
      transform: translateY(18px) rotate(1.2deg);
    }
  }

  @keyframes wave-drift-b {
    from {
      transform: translateY(14px) rotate(1deg) scale(1.02);
    }
    to {
      transform: translateY(-14px) rotate(-1deg) scale(1);
    }
  }

  /* 金色粒子：呼吸發光 */
  .gold-particle {
    transform-box: fill-box;
    transform-origin: center;
    animation: particle-glow var(--dur, 2.5s) ease-in-out infinite;
  }

  @keyframes particle-glow {
    0%,
    100% {
      opacity: 0.25;
      transform: scale(0.7);
    }
    50% {
      opacity: 1;
      transform: scale(1.15);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .wave-drift-a,
    .wave-drift-b,
    .gold-particle {
      animation: none;
    }
  }

  /* 手機：改為靜態絕對定位（只鋪首屏），停用動畫，避免捲動重繪造成卡頓 */
  @media (max-width: 640px) {
    .gold-waves {
      position: absolute;
      height: 100vh;
    }
    .wave-drift-a,
    .wave-drift-b,
    .gold-particle {
      animation: none;
    }
  }
</style>
